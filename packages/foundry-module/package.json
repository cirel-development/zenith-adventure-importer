{
  "name": "zenith-adventure-importer",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && node scripts/verify-build.mjs",
    "typecheck": "tsc --noEmit",
    "sample": "tsx samples/build-sample.ts && tsx samples/round-trip-test.ts",
    "deploy": "npm run build && cp -r dist/* /opt/foundrydata/Data/modules/zenith-adventure-importer/ && pm2 restart foundry",
    "bump": "node scripts/bump-version.mjs"
  },
  "dependencies": {
    "@ai-adventure/contract": "workspace:*",
    "fflate": "^0.8.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
